{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "unduck",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-22",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // Only intercept "/" (where ?q= redirects happen) so every other asset
    // request is served straight from the edge without invoking the Worker.
    "run_worker_first": ["/"]
  },
  "observability": {
    "enabled": true
  }
}
